{
    "__inputs": [
      { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" },
      { "name": "DS_LOKI", "label": "Loki", "type": "datasource", "pluginId": "loki" }
    ],
    "description": "Pango QA Automation",
    "editable": true,
    "graphTooltip": 1,
    "panels": [
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "id": 1,
        "title": "Daily Success Rate",
        "type": "stat",
        "fieldConfig": {
          "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 95 }] } }
        },
        "targets": [{ "expr": "100 * sum(increase(playwright_tests_passed_total{job=\"pango-qa\"}[24h])) / (sum(increase(playwright_tests_passed_total{job=\"pango-qa\"}[24h])) + sum(increase(playwright_tests_failed_total{job=\"pango-qa\"}[24h])))" }]
      },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "id": 2,
        "title": "Failed Tests Today",
        "type": "stat",
        "fieldConfig": {
          "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }
        },
        "targets": [{ "expr": "sum(increase(playwright_tests_failed_total{job=\"pango-qa\"}[24h]))" }]
      },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "id": 4,
        "title": "Duplicate Parking Prevention",
        "type": "stat",
        "fieldConfig": {
          "defaults": { "mappings": [{ "options": { "0": { "color": "red", "text": "BLOCKED" }, "1": { "color": "green", "text": "ACTIVE" } }, "type": "value" }] }
        },
        "targets": [{ "expr": "playwright_test_status{test_name=\"test_e2e_duplicate_parking_prevention\", job=\"pango-qa\"}" }]
      },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "id": 6,
        "title": "JS Console Errors",
        "type": "stat",
        "fieldConfig": {
          "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }
        },
        "targets": [{ "expr": "sum(playwright_console_errors_total{job=\"pango-qa\"})" }]
      },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "id": 7,
        "title": "Success / Failure Trends",
        "type": "timeseries",
        "targets": [
          { "expr": "sum(increase(playwright_tests_passed_total{job=\"pango-qa\"}[1h]))", "legendFormat": "Passed" },
          { "expr": "sum(increase(playwright_tests_failed_total{job=\"pango-qa\"}[1h]))", "legendFormat": "Failed" }
        ]
      },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "id": 11,
        "title": "History Data Integrity",
        "type": "gauge",
        "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
        "targets": [{ "expr": "100 * pango_history_slot_match_total / (pango_history_slot_match_total + pango_history_slot_mismatch_total)" }]
      },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
        "id": 16,
        "title": "Per-Test Status Table",
        "type": "table",
        "targets": [{ "expr": "playwright_test_status{job=\"pango-qa\"}", "format": "table", "instant": true }]
      },
      {
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
        "id": 17,
        "title": "Test Failure Logs (Loki)",
        "type": "logs",
        "targets": [{ "expr": "{job=\"pango-qa\"} |= \"FAILED\" | json", "refId": "A" }]
      },
      {
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
        "id": 18,
        "title": "JS Console Errors Log",
        "type": "logs",
        "targets": [{ "expr": "{job=\"pango-qa\", log_type=\"console_error\"} | json", "refId": "A" }]
      },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "gridPos": { "h": 4, "w": 24, "x": 0, "y": 28 },
        "id": 3,
        "title": "Avg Test Suite Duration (ms)",
        "type": "stat",
        "targets": [{ "expr": "avg(playwright_test_duration_ms{job=\"pango-qa\"})" }]
      }
    ],
    "refresh": "1m",
    "schemaVersion": 38,
    "title": "Pango QA — Executive Dashboard (Top 10)",
    "uid": "pango-qa-top-10",
    "version": 1
  }